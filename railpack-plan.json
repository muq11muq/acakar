{
  "install": [
    "python -m venv /app/.venv",
    "pip install -r requirements.txt"
  ],
  "build": [
    "PYTHONPATH=/app pip install -r requirements.txt",
    "PYTHONPATH=/app python manage.py collectstatic --noinput",
    "PYTHONPATH=/app python manage.py migrate --noinput"
  ],
  "deploy": "PYTHONPATH=/app gunicorn dalal_project.wsgi:application --bind 0.0.0.0:$PORT --workers 2 --timeout 120"
}
