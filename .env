# Django
SECRET_KEY=django-insecure-dev-only-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database: sqlite | postgresql | mysql
DB_ENGINE=sqlite

# PostgreSQL (Railway / Render) — use DATABASE_URL or individual vars
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DB_NAME=dalal
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# MySQL (optional)
# DB_ENGINE=mysql
# DB_NAME=dalal_db
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306

# Production security
SECURE_SSL_REDIRECT=True

# Optional Redis cache for rate limiting at scale
# REDIS_URL=redis://localhost:6379/0

SITE_NAME=دلال
