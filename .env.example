# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,acakar-production.up.railway.app
CSRF_TRUSTED_ORIGINS=https://acakar-production.up.railway.app

# Database: sqlite | postgresql | mysql
DB_ENGINE=mysql

# MySQL (Railway - Railway will automatically set DATABASE_URL)
# DATABASE_URL=mysql://user:password@host:3306/dbname
# For Railway, DATABASE_URL is set automatically when you add a MySQL database

# MySQL (Docker default)
DB_NAME=dalal_db
DB_USER=dalal_user
DB_PASSWORD=dalal_password
DB_HOST=db
DB_PORT=3306

# PostgreSQL (Railway / Render) — use DATABASE_URL or individual vars
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DB_NAME=dalal
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# SQLite (local development without Docker)
# DB_ENGINE=sqlite

# Production security
SECURE_SSL_REDIRECT=True

# Railway-specific
RAILWAY_PUBLIC_DOMAIN=acakar-production.up.railway.app

# Optional Redis cache for rate limiting at scale
# REDIS_URL=redis://localhost:6379/0

SITE_NAME=دلال
